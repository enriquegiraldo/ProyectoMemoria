generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Memory {
  id           String        @id @default(cuid())
  title        String
  content      String
  type         MemoryType    @default(MESSAGE)
  imageUrl     String?
  videoUrl     String?
  isPublic     Boolean       @default(true)
  isFeatured   Boolean       @default(false)
  publishedAt  DateTime?     @default(now())
  eventDate    DateTime?
  location     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  eventId      String?
  authorId     String
  categoryId   String?
  file_size    Int?
  comments     Comment[]     @relation("CommentMemory")
  likes        Like[]        @relation("LikeMemory")
  author       User          @relation("MemoryCreatedBy", fields: [authorId], references: [id], onDelete: Cascade)
  category     Category?     @relation("MemoryCategory", fields: [categoryId], references: [id])
  event        Event?        @relation("EventMemory", fields: [eventId], references: [id], onDelete: Cascade)
  testimonials Testimonial[] @relation("TestimonialMemory")
  tags         Tag[]         @relation("MemoryTag")

  @@map("memories")
}

model Testimonial {
  id           String   @id @default(cuid())
  content      String
  isApproved   Boolean  @default(false)
  relationship String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  authorId     String
  memoryId     String?
  author       User     @relation("TestimonialCreatedBy", fields: [authorId], references: [id], onDelete: Cascade)
  memory       Memory?  @relation("TestimonialMemory", fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("testimonials")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memories    Memory[] @relation("MemoryCategory")

  @@map("categories")
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  name                   String
  password               String
  role                   Role               @default(USER)
  bio                    String?
  avatarUrl              String?
  relationship           String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  last_payment_date      DateTime?
  last_payment_failed    DateTime?
  stripe_customer_id     String?
  stripe_subscription_id String?
  subscription_end_date  DateTime?
  subscription_plan      SubscriptionPlan   @default(FREE)
  subscription_status    SubscriptionStatus @default(ACTIVE)
  apiKeys                ApiKey[]
  comments               Comment[]          @relation("CommentCreatedBy")
  events                 Event[]            @relation("EventCreatedBy")
  likes                  Like[]             @relation("LikeUser")
  memories               Memory[]           @relation("MemoryCreatedBy")
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  testimonials           Testimonial[]      @relation("TestimonialCreatedBy")
  userBadges             UserBadge[]
  userMissions           UserMission[]
  userPoints             UserPoints?

  @@map("users")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  memories  Memory[] @relation("MemoryTag")

  @@map("tags")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  memoryId  String
  author    User     @relation("CommentCreatedBy", fields: [authorId], references: [id], onDelete: Cascade)
  memory    Memory   @relation("CommentMemory", fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  memoryId  String
  memory    Memory   @relation("LikeMemory", fields: [memoryId], references: [id], onDelete: Cascade)
  user      User     @relation("LikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, memoryId])
  @@map("likes")
}

model Event {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String
  createdBy   User      @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  memories    Memory[]  @relation("EventMemory")

  @@map("events")
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  properties Json?
  user_id    String?
  timestamp  DateTime @default(now())
  session_id String?
  user_agent String?
  page_url   String?
  ip_address String?

  @@map("analytics_events")
}

model Notification {
  id         String    @id @default(cuid())
  user_id    String
  title      String
  message    String
  type       String
  category   String
  data       Json?
  is_read    Boolean   @default(false)
  read_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PushSubscription {
  id         String   @id @default(cuid())
  user_id    String
  endpoint   String
  p256dh     String
  auth       String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, endpoint])
  @@map("push_subscriptions")
}

model UserPoints {
  id                  String   @id @default(cuid())
  user_id             String   @unique
  points              Int      @default(0)
  level               Int      @default(1)
  experience          Int      @default(0)
  total_points_earned Int      @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model Badge {
  id              String      @id @default(cuid())
  name            String      @unique
  description     String
  icon            String
  color           String
  points_required Int
  category        String
  is_hidden       Boolean     @default(false)
  created_at      DateTime    @default(now())
  missions        Mission[]   @relation("BadgeReward")
  userBadges      UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(cuid())
  user_id     String
  badge_id    String
  earned_at   DateTime @default(now())
  is_featured Boolean  @default(false)
  badge       Badge    @relation(fields: [badge_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_id])
  @@map("user_badges")
}

model Mission {
  id            String        @id @default(cuid())
  name          String
  description   String
  type          String
  target        Int
  points_reward Int
  badge_reward  String?
  is_active     Boolean       @default(true)
  created_at    DateTime      @default(now())
  badge         Badge?        @relation("BadgeReward", fields: [badge_reward], references: [id])
  userMissions  UserMission[]

  @@map("missions")
}

model UserMission {
  id           String    @id @default(cuid())
  user_id      String
  mission_id   String
  progress     Int       @default(0)
  completed    Boolean   @default(false)
  completed_at DateTime?
  started_at   DateTime  @default(now())
  mission      Mission   @relation(fields: [mission_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, mission_id])
  @@map("user_missions")
}

model PointTransaction {
  id          String   @id @default(cuid())
  user_id     String
  points      Int
  type        String
  activity    String
  description String
  created_at  DateTime @default(now())

  @@map("point_transactions")
}

model ApiKey {
  id          String    @id @default(cuid())
  user_id     String
  name        String
  key_hash    String    @unique
  permissions Json
  rate_limit  Int       @default(1000)
  is_active   Boolean   @default(true)
  last_used   DateTime?
  expires_at  DateTime?
  created_at  DateTime  @default(now())
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Webhook {
  id             String    @id @default(cuid())
  user_id        String
  url            String
  events         Json
  secret         String
  is_active      Boolean   @default(true)
  last_triggered DateTime?
  created_at     DateTime  @default(now())

  @@map("webhooks")
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum MemoryType {
  MESSAGE
  PHOTO
  VIDEO
  AUDIO
  DOCUMENT
  TRIBUTE
  STORY
  MILESTONE
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIAL
}
