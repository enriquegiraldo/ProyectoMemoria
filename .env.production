# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5555/memoria_eterna"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Email Configuration (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Stripe Product Price IDs
STRIPE_BASIC_PRICE_ID="price_your-basic-plan-id"
STRIPE_PRO_PRICE_ID="price_your-pro-plan-id"
STRIPE_ENTERPRISE_PRICE_ID="price_your-enterprise-plan-id"

# Base URL for Stripe redirects
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Analytics (Optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_MIXPANEL_TOKEN="your-mixpanel-token"

# App Configuration
NEXT_PUBLIC_APP_NAME="Memoria Eterna"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_ENABLE_ANALYTICS="true"
NEXT_PUBLIC_ENABLE_PAYMENTS="true"
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS="true"

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="your-redis-password"

# CDN Configuration
CDN_URL="https://cdn.memoriaeterna.com"
CDN_API_KEY="your-cdn-api-key"

# Google APIs
GOOGLE_ANALYTICS_ID="GA_MEASUREMENT_ID"
GOOGLE_MAPS_API_KEY="your-google-maps-key"
GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-oauth-client-secret"

# Facebook APIs
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_PIXEL_ID="your-facebook-pixel-id"

# Email Service (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="noreply@memoriaeterna.com"

# Monitoring
SENTRY_DSN="your-sentry-dsn"
LOGROCKET_APP_ID="your-logrocket-app-id"

# Redes Sociales - Fase 9
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"
TWITTER_API_KEY="your_twitter_api_key"
TWITTER_API_SECRET="your_twitter_api_secret"
INSTAGRAM_APP_ID="your_instagram_app_id"
INSTAGRAM_APP_SECRET="your_instagram_app_secret"
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"

# Email Services - Fase 9
SENDGRID_API_KEY="your_sendgrid_api_key"
MAILGUN_API_KEY="your_mailgun_api_key"
MAILGUN_DOMAIN="your_mailgun_domain"
MAILCHIMP_API_KEY="your_mailchimp_api_key"
MAILCHIMP_LIST_ID="your_mailchimp_list_id"

# Marketing - Fase 9
HUBSPOT_API_KEY="your_hubspot_api_key"
GOOGLE_ANALYTICS_ID="your_ga4_id"
FACEBOOK_PIXEL_ID="your_facebook_pixel_id"

# IA - Fase 9
OPENAI_API_KEY="your_openai_api_key"
GOOGLE_CLOUD_VISION_API_KEY="your_google_vision_api_key"

# Automatización - Fase 9
CRON_SECRET="your_cron_secret"
AUTOMATION_WEBHOOK_SECRET="your_automation_webhook_secret"

# ========================================
# FASE 10: ESCALABILIDAD Y ENTERPRISE
# ========================================

# Kubernetes Configuration
KUBERNETES_CLUSTER_URL="https://your-cluster.example.com"
KUBERNETES_TOKEN="your-kubernetes-token"
KUBERNETES_NAMESPACE="memoria-eterna"

# Service Mesh (Istio)
ISTIO_GATEWAY_URL="https://gateway.memoriaeterna.com"
ISTIO_INGRESS_URL="https://ingress.memoriaeterna.com"

# Message Queues
RABBITMQ_URL="amqp://localhost:5672"
KAFKA_BROKERS="localhost:9092"
AWS_SQS_QUEUE_URL="https://sqs.region.amazonaws.com/account/queue"

# Service Discovery
CONSUL_URL="http://localhost:8500"
ETCD_URL="http://localhost:2379"

# Security & Authentication
AUTH0_DOMAIN="your-domain.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"
AUTH0_AUDIENCE="https://api.memoriaeterna.com"

# SAML Configuration
SAML_ENTRY_POINT="https://your-idp.com/sso"
SAML_ISSUER="https://memoriaeterna.com"
SAML_CERT="your-saml-certificate"

# 2FA Configuration
TOTP_SECRET="your-totp-secret"
SMS_PROVIDER_API_KEY="your-sms-provider-key"
SMS_PROVIDER_SECRET="your-sms-provider-secret"

# Encryption & Secrets Management
VAULT_URL="http://localhost:8200"
VAULT_TOKEN="your-vault-token"
ENCRYPTION_KEY="your-32-character-encryption-key"
JWT_SECRET="your-jwt-secret-key"

# Certificate Management
CERT_MANAGER_EMAIL="admin@memoriaeterna.com"
SSL_CERT_PATH="/path/to/ssl/certificate"
SSL_KEY_PATH="/path/to/ssl/private-key"

# Compliance & GDPR
GDPR_DATA_RETENTION_DAYS="2555"
GDPR_CONSENT_REQUIRED="true"
HIPAA_COMPLIANCE_ENABLED="true"
SOC2_AUDIT_ENABLED="true"

# Multi-tenancy
MULTI_TENANT_ENABLED="true"
TENANT_ISOLATION_MODE="database" # database, schema, or row
DEFAULT_TENANT_ID="default"

# Monitoring & Observability
NEW_RELIC_LICENSE_KEY="your-newrelic-license-key"
NEW_RELIC_APP_NAME="Memoria Eterna"
DATADOG_API_KEY="your-datadog-api-key"
DATADOG_APP_KEY="your-datadog-app-key"

# APM Configuration
APM_SERVICE_NAME="memoria-eterna-api"
APM_SERVICE_VERSION="1.0.0"
APM_ENVIRONMENT="production"

# Logging
ELASTICSEARCH_URL="http://localhost:9200"
LOG_LEVEL="info"
LOG_FORMAT="json"
LOG_RETENTION_DAYS="30"

# Metrics & Prometheus
PROMETHEUS_URL="http://localhost:9090"
GRAFANA_URL="http://localhost:3001"
METRICS_PORT="9090"

# Tracing
JAEGER_URL="http://localhost:16686"
ZIPKIN_URL="http://localhost:9411"
TRACING_SAMPLE_RATE="0.1"

# Alerting
PAGERDUTY_API_KEY="your-pagerduty-api-key"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/your/webhook/url"
ALERT_EMAIL="alerts@memoriaeterna.com"

# Performance & Scaling
AUTO_SCALING_ENABLED="true"
MIN_REPLICAS="2"
MAX_REPLICAS="10"
TARGET_CPU_UTILIZATION="70"
TARGET_MEMORY_UTILIZATION="80"

# CDN & Global Distribution
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
AWS_CLOUDFRONT_DISTRIBUTION_ID="your-cloudfront-distribution-id"
CDN_CACHE_TTL="3600"

# Database Scaling
DB_READ_REPLICAS="3"
DB_WRITE_REPLICAS="1"
DB_SHARDING_ENABLED="true"
DB_CONNECTION_POOL_SIZE="20"

# Cache Distribution
REDIS_CLUSTER_ENABLED="true"
REDIS_CLUSTER_NODES="redis-1:6379,redis-2:6379,redis-3:6379"
MEMCACHED_URL="localhost:11211"

# Infrastructure as Code
TERRAFORM_STATE_BUCKET="memoria-eterna-terraform-state"
TERRAFORM_STATE_REGION="us-west-2"
ANSIBLE_INVENTORY_PATH="/path/to/ansible/inventory"

# CI/CD
JENKINS_URL="https://jenkins.memoriaeterna.com"
GITLAB_CI_TOKEN="your-gitlab-ci-token"
ARGOCD_SERVER="https://argocd.memoriaeterna.com"
ARGOCD_TOKEN="your-argocd-token"

# Security Scanning
TRIVY_SERVER_URL="http://localhost:8080"
FALCO_RULES_PATH="/etc/falco/rules"
OPA_POLICY_PATH="/path/to/opa/policies"

# Backup & Disaster Recovery
BACKUP_S3_BUCKET="memoria-eterna-backups"
BACKUP_RETENTION_DAYS="90"
DISASTER_RECOVERY_ENABLED="true"
RTO_TARGET_SECONDS="300"
RPO_TARGET_SECONDS="60"
