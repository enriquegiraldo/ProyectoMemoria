{
  "name": "notifications-service",
  "version": "1.0.0",
  "description": "Notifications Service for Memoria Eterna Platform",
  "main": "dist/server.js",
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "node-fetch": "^2.6.7"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docker:build": "docker build -t notifications-service .",
    "docker:run": "docker run -p 3003:3003 notifications-service"
  },
  "keywords": [
    "notifications",
    "email",
    "push",
    "sms",
    "webhooks",
    "microservice"
