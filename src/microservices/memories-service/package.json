{
  "name": "memories-service",
  "version": "1.0.0",
  "description": "Memories Service for Memoria Eterna Platform",
  "main": "dist/index.js",
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "node-fetch": "^2.6.7"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docker:build": "docker build -t memories-service .",
    "docker:run": "docker run -p 3002:3002 memories-service",
    "health": "curl http://localhost:3002/health",
    "metrics": "curl http://localhost:3002/metrics",
    "logs": "docker logs -f memories-service",
    "logs:error": "docker logs -f memories-service 2>&1 | grep ERROR"
  },
  "keywords": [
    "memories",
    "microservice",
    "memoria-eterna",
    "typescript",
    "express",
    "supabase"
  ],
  "author": "Memoria Eterna Team",
